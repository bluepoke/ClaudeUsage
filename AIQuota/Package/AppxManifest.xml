<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX manifest for Store submission (Desktop Bridge / full-trust Win32 app).

  Identity/Name and Identity/Publisher below are the values reserved in Partner Center
  (Store settings > App management > App identity) - fixed per app registration, never
  change between releases. PublisherDisplayName is assumed to match; adjust it if Partner
  Center shows something different. Version is overwritten per build by the release
  workflow (from the git tag) - leave it as-is.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap mp rescap">

  <Identity
    Name="PeterKossek.ClaudeUsageTray"
    Publisher="CN=23958C63-4B3B-41E3-A146-57957965CE1C"
    Version="1.0.0.0" />

  <Properties>
    <DisplayName>AI Quota</DisplayName>
    <PublisherDisplayName>Peter Kossek</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
    <Resource Language="de-de" />
  </Resources>

  <Applications>
    <Application Id="AIQuota" Executable="AIQuota.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="AI Quota"
        Description="Shows Claude.ai Pro/Max plan usage limits in the Windows system tray."
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="Assets\Wide310x150Logo.png"
          Square71x71Logo="Assets\Square71x71Logo.png"
          Square310x310Logo="Assets\Square310x310Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
